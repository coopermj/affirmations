DATABASE_URL="postgresql://user:password@localhost:5432/affirmations"
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-with: openssl rand -base64 32"

# Break-glass admin: when both are set, these credentials always grant admin
# access and self-heal the DB user. Keep them safe — they are your recovery login.
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD=""
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_BUCKET_NAME=""
R2_SECRET_ACCESS_KEY=""
R2_PUBLIC_URL="https://<account-id>.r2.cloudflarestorage.com/<bucket-name>"

# Passkeys (WebAuthn). Optional — if unset, these are derived from NEXTAUTH_URL
# (host → RP ID, origin → RP origin), falling back to localhost in dev. Set them
# explicitly in production. RP ID must exactly match the served host.
WEBAUTHN_RP_ID="affirmations.example.com"
WEBAUTHN_RP_ORIGIN="https://affirmations.example.com"
WEBAUTHN_RP_NAME="Affirmations"
